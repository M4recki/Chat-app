# Database Configuration
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/chatapp

# Security
SECRET_KEY=your-super-secret-key-change-this-in-production
CHAT_SECRET_KEY=your-chat-secret-key-change-this-in-production

# Email Configuration (Gmail SMTP)
EMAIL_RECEIVER=your-admin-email@gmail.com
EMAIL_PASSWORD=your-app-specific-password

# AI Configuration
AI_KEY=your-nvidia-api-key
CHATBOT_HISTORY_LIMIT=8
CHATBOT_MAX_TOKENS=2048
CHATBOT_TIMEOUT_SECONDS=60
CHATBOT_MAX_RETRIES=3

# Rate limiting
RATE_LIMIT_LOGIN_MAX_REQUESTS=10
RATE_LIMIT_LOGIN_WINDOW_SECONDS=60
RATE_LIMIT_CHATBOT_MAX_REQUESTS=8
RATE_LIMIT_CHATBOT_WINDOW_SECONDS=60
RATE_LIMIT_SEARCH_MAX_REQUESTS=30
RATE_LIMIT_SEARCH_WINDOW_SECONDS=60

# Environment
ENVIRONMENT=development
DEBUG=True

# Note: TESTING env var is automatically set to "1" during test runs by conftest.py
# Do not set it manually in production or development .env
